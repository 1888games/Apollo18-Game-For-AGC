000190,000050: 
000191,000051:    4151           50110                          INDEX    ALM_ID                        	# Index using segment id
000192,000052:    4152           30113                          CA       SIGNAL                        	# Get the signal num in other slot
000193,000053: 
000194,000054:    4153           00006                          EXTEND                                 	#
000195,000055:    4154           60125                          SU       GUESS_NOW                     	# Subtract the guess in main slot
000196,000056:    4155           00006                          EXTEND                                 	#

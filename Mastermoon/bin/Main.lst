000716,000006:    4615           30111                          CA       ENTER_IDX                     	#
000717,000007:    4616           00006                          EXTEND                                 	#
000718,000008:    4617           60061                          SU       TEMPI                         	#
000719,000009:    4620           00006                          EXTEND                                 	#
000720,000010:    4621           14630                          BZF      NO_CLR                        	#
000721,000011: 

000167,000027:    4134           30113                          CA       SIGNAL                        	# Get signal num in this slot
000168,000028:    4135           54126                          TS       SIG_NOW                       	# Store in ram
000169,000029: 
000170,000030: 
000171,000031:    4136           00006                          EXTEND                                 	#
000172,000032:    4137           60125                          SU       GUESS_NOW                     	# Subtract guess from signal
000173,000033:    4140           00006                          EXTEND                                 	#
000174,000034:    4141           14171                          BZF      IS_RIGHT                      	# If guess-signal=0, must be right
000175,000035: 
000176,000036: 

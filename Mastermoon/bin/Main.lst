000384,000094: 
000385,000095:    4330           35120                          CA       HS_LS_IDX                     	# Get index of last history slot
000386,000096:    4331           54074                          TS       CUR_ID                        	# store in variable
000387,000097: 
000388,000098:    4332                        CLR_LOOP                                                 	#
000389,000099: 
000390,000100:    4332           35104                          CA       NEG_ONE                       	# Load -1 into A	
000391,000101:    4333           50074                          INDEX    CUR_ID                        	# Index by current history slot
000392,000102:    4334           54160                          TS       PREV_GUESS                    	# Store -1 to history array
000393,000103: 
000394,000104:    4335           30074                          CA       CUR_ID                        	# Load current index
000395,000105:    4336           00006                          EXTEND                                 	#
000396,000106:    4337           14344                          BZF      CLR_DONE                      	# If it's 0, we are done
000397,000107: 
000398,000108:    4340           00006                          EXTEND                                 	#
000399,000109:    4341           26074                          DIM      CUR_ID                        	# Decrement current id
000400,000110: 
000401,000111:    4342           40067                          CS       NEWJOB                        	# Each loop, nudge hardware watchdog 		
000402,000112: 
000403,000113:    4343           14332                          TCF      CLR_LOOP                      	# Do next slot in history array
000404,000114: 
000405,000115:    4344                        CLR_DONE                                                 	#
000406,000116: 
000407,000117: 
000408,000118:    4344           00003                          RELINT                                 	# Enable interrupts
000409,000119:    4345           24124                          INCR     FIRST_RUN                     	# Set flag that game has run once
000410,000120: 
000411,000121:    4346           14074                          TCF      MAINLOOP                      	# Go back to main loop
(End of include-file NewGame.agc, resuming Main.agc)
000412,000062: $NumPress.agc
000413,000001: 
000414,000002:    4347                        NUM_PRESS                                                 	#
000415,000003: 
000416,000004:    4347           50111                          INDEX    ENTER_IDX                     	# Get index of segment to populate next	
000417,000005:    4350           54131                          TS       VALUES                        	# Store key number pressed in array
000418,000006: 
000419,000007:    4351           00006                          EXTEND                                 	#
000420,000008:    4352           60120                          SU       ZERO_IDX                      	# Subtract 16 from key press index
000421,000009:    4353           00006                          EXTEND                                 	#
000422,000010:    4354           14356                          BZF      ZERO_PRESS                    	# If 0, zero key was pressed	
000423,000011: 
000424,000012:    4355           14361                          TCF      NOT_ZERO                      	# Not zero, skip
000425,000013: 
000426,000014:    4356                        ZERO_PRESS                                                 	#
000427,000015: 
000428,000016:    4356           30007                          CA       ZERO                          	# Load 0 into A
000429,000017:    4357           50111                          INDEX    ENTER_IDX                     	# Get index of segment to populate
000430,000018:    4360           54131                          TS       VALUES                        	# Override value saved earlier with 0
000431,000019: 
000432,000020:    4361                        NOT_ZERO                                                 	#
000433,000021: 
000434,000022:    4361           04631                          TC       DISPALL                       	# Need to display all as digits are drawn in pairs	
000435,000023:    4362           24111                          INCR     ENTER_IDX                     	# Move to next index
000436,000024: 
000437,000025:    4363           35236                          CA       DEC11                         	# Load 11 into A
000438,000026:    4364           54061                          TS       TEMPI                         	# Store in temp variable for subtraction
000439,000027: 
000440,000028:    4365           30111                          CA       ENTER_IDX                     	# What's the next index?
000441,000029:    4366           00006                          EXTEND                                 	#
000442,000030:    4367           60061                          SU       TEMPI                         	# Subtract 11 from it
000443,000031:    4370           00006                          EXTEND                                 	#
000444,000032:    4371           14373                          BZF      CHECKNEW                      	# If A = 0, we entered 5 digits already
000445,000033: 
000446,000034:    4372           14074                          TCF      MAINLOOP                      	# Return to main loop
000447,000035: 
000448,000036: 
000449,000037:    4373                        CHECKNEW                                                 	#
000450,000038: 
000451,000039:    4373           04465                          TC       STOREGUESS                    	# Copy guess down to row 2, shift guess history array
000452,000040:    4374           04120                          TC       CHECKGUESS                    	# Check accuracy of guess
000453,000041:    4375           14376                          TCF      DO_TURNS                      	#
000454,000042: 
(End of include-file NumPress.agc, resuming Main.agc)
000455,000063: $UpdateTurn.agc
000456,000001: 
000457,000002:    4376                        DO_TURNS                                                 	#
000458,000003: 
000459,000004:    4376           30131                          CA       TURN_TEN                      	# Load number of tens in turns left
000460,000005:    4377           00006                          EXTEND                                 	#
000461,000006:    4400           14414                          BZF      TENS_ZERO                     	# Tens is zero, just decrease ones
000462,000007: 
000463,000008:    4401           30132                          CA       TURN_DIG                      	# Load number of ones in turn count
000464,000009:    4402           00006                          EXTEND                                 	#
000465,000010:    4403           14407                          BZF      WRAP_TEN                      	# If zero, decrease tens
000466,000011: 
000467,000012:    4404           00006                          EXTEND                                 	#
000468,000013:    4405           26132                          DIM      TURN_DIG                      	# Decrease ones
000469,000014: 
000470,000015:    4406           14451                          TCF      DONE_TURNS                    	# We know tens > 0, skip the rest
000471,000016: 
000472,000017:    4407                        WRAP_TEN                                                 	#
000473,000018: 
000474,000019:    4407           00006                          EXTEND                                 	#
000475,000020:    4410           26131                          DIM      TURN_TEN                      	# Decrease number of tens
000476,000021: 
000477,000022:    4411           35234                          CA       DEC9                          	# Load 9 into A
000478,000023:    4412           54132                          TS       TURN_DIG                      	# Store into turn ones
000479,000024: 
000480,000025:    4413           14451                          TCF      DONE_TURNS                    	# We know we can't be out of turns, skip rest
000481,000026: 
000482,000027:    4414                        TENS_ZERO                                                 	#
000483,000028: 
000484,000029:    4414           00006                          EXTEND                                 	#
000485,000030:    4415           26132                          DIM      TURN_DIG                      	# Decrease number in ones	
000486,000031: 
000487,000032:    4416           30076                          CA       GM_STATE                      	# Get game state
000488,000033:    4417           00006                          EXTEND                                 	#
000489,000034:    4420           14422                          BZF      NOT_WON                       	# Still playing	
000490,000035: 
000491,000036:    4421           14452                          TCF      IS_GM_OVR                     	# We won, don't check game over
000492,000037: 
000493,000038:    4422                        NOT_WON                                                  	#
000494,000039:    4422           30132                          CA       TURN_DIG                      	# Load ones into A
000495,000040:    4423           00006                          EXTEND                                 	#
000496,000041:    4424           14426                          BZF      NONE_LEFT                     	# If ones is zero
000497,000042: 
000498,000043:    4425           14451                          TCF      DONE_TURNS                    	# Ones > 0, not out of turns
000499,000044: 
000500,000045:    4426                        NONE_LEFT                                                 	#
000501,000046: 
000502,000047:    4426           35122                          CA       OPP_ERR                       	# Load bit pattern for operator error light
000503,000048:    4427           00006                          EXTEND                                 	#
000504,000049:    4430           05011                          WOR      CH11                          	# Turn bit on
000505,000050: 
000506,000051:    4431           35226                          CA       STALOSE                       	# Load status id for lost condition
000507,000052:    4432           54076                          TS       GM_STATE                      	# Store in game state var
000508,000053: 
000509,000054:    4433           35100                          CAF      GM_TIME                       	# Get timer value to show game over 
000510,000055:    4434           54027                          TS       TIME4                         	# Set interrupt to fire when timer (counts up) wraps to 0
000511,000056: 
000512,000057:    4435           04104                          TC       RESETALL                      	# Set all grid items to empty (-1)
000513,000058: 
000514,000059:    4436           30113                          CA       SIGNAL                        	# Copy correct answer to bottom row
000515,000060:    4437           54151                          TS       NUM_10                        	#
000516,000061: 
000517,000062:    4440           30114                          CA       SIGNAL1                       	#
000518,000063:    4441           54152                          TS       NUM_11                        	#
000519,000064: 
000520,000065:    4442           30115                          CA       SIGNAL2                       	#
000521,000066:    4443           54153                          TS       NUM_12                        	#
000522,000067: 
000523,000068:    4444           30116                          CA       SIGNAL3                       	#
000524,000069:    4445           54154                          TS       NUM_13                        	#
000525,000070: 
000526,000071:    4446           30117                          CA       SIGNAL4                       	#
000527,000072:    4447           54155                          TS       NUM_14                        	#
000528,000073: 
000529,000074:    4450           14452                          TCF      IS_GM_OVR                     	# Don't update guess history, who cares, you lost!
000530,000075: 
000531,000076:    4451                        DONE_TURNS                                                 	#
000532,000077: 
000533,000078:    4451           04542                          TC       DISP_HIST                     	# Update guess history	
000534,000079: 
000535,000080:    4452                        IS_GM_OVR                                                 	#
000536,000081: 
000537,000082:    4452           04631                          TC       DISPALL                       	# Refresh DSKY
000538,000083: 
000539,000084:    4453           14074                          TCF      MAINLOOP                      	# Return to main loop
000540,000085: 
(End of include-file UpdateTurn.agc, resuming Main.agc)
000541,000064: $WinState.agc
000542,000001:    4454                        UPDATE_WIN                                                 	#
000543,000002: 
000544,000003:    4454           35072                          CA       NOKEY                         	# Load key code for 'no key pressed'
000545,000004:    4455           00006                          EXTEND                                 	#
000546,000005:    4456           60070                          SU       KEYBUF                        	# Subtract the key code read
000547,000006:    4457           00006                          EXTEND                                 	#
000548,000007:    4460           14464                          BZF      NOTYET                        	# If zero, nothing pressed, continue waiting
000549,000008: 
000550,000009:    4461           35072                          CA       NOKEY                         	# Clear keyboard buffer so not carried into game
000551,000010:    4462           54070                          TS       KEYBUF                        	#
000552,000011: 
000553,000012:    4463           14056                          TCF      INIT2                         	# Jump to set up new game
000554,000013: 
000555,000014:    4464                        NOTYET                                                   	#
000556,000015: 
000557,000016:    4464           14074                          TCF      MAINLOOP                      	#
000558,000017: 
000559,000018: 
000560,000019: 
000561,000020: 
(End of include-file WinState.agc, resuming Main.agc)
000562,000065: $StoreGuess.agc
000563,000001:    4465                        STOREGUESS                                                 	#
000564,000002: 
000565,000003:    4465           35231                          CA       DEC6                          	# Load 6 into A
000566,000004:    4466           54111                          TS       ENTER_IDX                     	# Store as segment for player to populate next
000567,000005: 
000568,000006:    4467           35117                          CA       CP_ST_IDX                     	# Load index to start from
000569,000007:    4470           54127                          TS       SRC_IDX                       	# Store into source index variable
000570,000008: 
000571,000009:    4471           65230                          AD       DEC5                          	# Add 5
000572,000010:    4472           54130                          TS       DES_IDX                       	# Store in destination index variable
000573,000011: 
000574,000012:    4473           30157                          CA       MAX_IDX                       	# Load current max history index
000575,000013:    4474           65230                          AD       DEC5                          	# Increase by 5
000576,000014:    4475           54157                          TS       MAX_IDX                       	# Store back in memory
000577,000015: 
000578,000016:    4476           30007                          CA       ZERO                          	# Load 0 into A
000579,000017:    4477           54156                          TS       HIS_IDX                       	# Reset a previous scrolled list
000580,000018: 
000581,000019:    4500                        COPY_LOOP                                                 	#
000582,000020: 
000583,000021: 
000584,000022:    4500           50127                          INDEX    SRC_IDX                       	# Index using source
000585,000023:    4501           30160                          CA       PREV_GUESS                    	# Get value from array
000586,000024: 
000587,000025:    4502           50130                          INDEX    DES_IDX                       	# Index using destination
000588,000026:    4503           54160                          TS       PREV_GUESS                    	# Store value into array
000589,000027: 
000590,000028:    4504           30127                          CA       SRC_IDX                       	# Load index just copied
000591,000029:    4505           00006                          EXTEND                                 	#
000592,000030:    4506           14514                          BZF      COPY_DONE                     	# If it's zero, we're done	
000593,000031: 
000594,000032:    4507           00006                          EXTEND                                 	#
000595,000033:    4510           26127                          DIM      SRC_IDX                       	# Reduce source index by 1
000596,000034: 
000597,000035:    4511           00006                          EXTEND                                 	#
000598,000036:    4512           26130                          DIM      DES_IDX                       	# Reduce dest index by 1
000599,000037: 
000600,000038:    4513           14500                          TCF      COPY_LOOP                     	# Keep going
000601,000039: 
000602,000040:    4514                        COPY_DONE                                                 	#
000603,000041: 
000604,000042:    4514           30137                          CA       NUM_GRID                      	# Copy guess in row 1 into prev guess history slot 0
000605,000043:    4515           54160                          TS       PREV_GUESS                    	#
000606,000044:    4516           54144                          TS       CHK_GRID                      	# and to row below of DSKY
000607,000045: 
000608,000046:    4517           30140                          CA       NUM_1                         	# Copy guess in row 1 into prev guess history slot 0
000609,000047:    4520           54161                          TS       PREV_1                        	#
000610,000048:    4521           54145                          TS       NUM_6                         	# and to row below of DSKY
000611,000049: 
000612,000050:    4522           30141                          CA       NUM_2                         	# Copy guess in row 1 into prev guess history slot 0
000613,000051:    4523           54162                          TS       PREV_2                        	#
000614,000052:    4524           54146                          TS       NUM_7                         	# and to row below of DSKY
000615,000053: 
000616,000054:    4525           30142                          CA       NUM_3                         	# Copy guess in row 1 into prev guess history slot 0
000617,000055:    4526           54163                          TS       PREV_3                        	#
000618,000056:    4527           54147                          TS       NUM_8                         	# and to row below of DSKY
000619,000057: 
000620,000058:    4530           30143                          CA       NUM_4                         	# Copy guess in row 1 into prev guess history slot 0
000621,000059:    4531           54164                          TS       PREV_4                        	#
000622,000060:    4532           54150                          TS       NUM_9                         	# and to row below of DSKY
000623,000061: 
000624,000062:    4533                        CLEARGUESS                                                 	#
000625,000063: 
000626,000064:    4533           35104                          CA       NEG_ONE                       	#
000627,000065:    4534           54137                          TS       NUM_GRID                      	#
000628,000066:    4535           54140                          TS       NUM_1                         	#
000629,000067:    4536           54141                          TS       NUM_2                         	#
000630,000068:    4537           54142                          TS       NUM_3                         	#
000631,000069:    4540           54143                          TS       NUM_4                         	#
000632,000070: 
000633,000071:    4541           00002                          RETURN                                 	#
000634,000072: 
(End of include-file StoreGuess.agc, resuming Main.agc)
000635,000066: $DisplayHistory.agc
000636,000001:    4542                        DISP_HIST                                                 	#
000637,000002: 
000638,000003:    4542           35236                          CA       DEC11                         	# Load 11 into A
000639,000004:    4543           54130                          TS       DES_IDX                       	# Store as destination index within DSKY array
000640,000005: 
000641,000006:    4544           30156                          CA       HIS_IDX                       	# Load current start history index
000642,000007:    4545           54127                          TS       SRC_IDX                       	# Store as source index within history array
000643,000008:    4546           65235                          AD       DEC10                         	# Add 10
000644,000009:    4547           54103                          TS       END_ID                        	# Store as the end id to check when done
000645,000010: 
000646,000011:    4550                        DISP_LOOP                                                 	#
000647,000012: 
000648,000013:    4550           50127                          INDEX    SRC_IDX                       	# Get current source index
000649,000014:    4551           30160                          CA       PREV_GUESS                    	# Get value from guess history
000650,000015: 
000651,000016:    4552           50130                          INDEX    DES_IDX                       	# Get current DSKY dest index
000652,000017:    4553           54131                          TS       VALUES                        	# Save value to DSKY array
000653,000018: 
000654,000019:    4554           24127                          INCR     SRC_IDX                       	# Increment source index
000655,000020:    4555           24130                          INCR     DES_IDX                       	# Increment dest index
000656,000021: 
000657,000022:    4556           30127                          CA       SRC_IDX                       	# Load source index
000658,000023:    4557           00006                          EXTEND                                 	#
000659,000024:    4560           60103                          SU       END_ID                        	# Subtract end id
000660,000025:    4561           00006                          EXTEND                                 	#
000661,000026:    4562           14564                          BZF      DIS_DONE                      	# If zero, finished copying
000662,000027: 
000663,000028:    4563           14550                          TCF      DISP_LOOP                     	# Not done, loop round again
000664,000029: 
000665,000030: 
000666,000031:    4564                        DIS_DONE                                                 	#
000667,000032: 
000668,000033:    4564           00002                          RETURN                                 	# return to caller
(End of include-file DisplayHistory.agc, resuming Main.agc)
000669,000067: $Scroll.agc
000670,000001:    4565                        SCROLL_UP                                                 	#
000671,000002: 
000672,000003:    4565           30156                          CA       HIS_IDX                       	# Load current start index
000673,000004:    4566           00006                          EXTEND                                 	#
000674,000005:    4567           60157                          SU       MAX_IDX                       	# Subtract maximum
000675,000006:    4570           00006                          EXTEND                                 	#
000676,000007:    4571           14601                          BZF      CANTSCROLL                    	# If 0, already at max, don't scroll
000677,000008: 
000678,000009:    4572           30156                          CA       HIS_IDX                       	# Load start index again
000679,000010:    4573           65230                          AD       DEC5                          	# Add five to move to next row
000680,000011:    4574           54156                          TS       HIS_IDX                       	# Store back in history index
000681,000012: 
000682,000013:    4575                        SCR_UPDT                                                 	#
000683,000014: 
000684,000015:    4575           04542                          TC       DISP_HIST                     	# Update guess history	
000685,000016:    4576           04120                          TC       CHECKGUESS                    	# Check if middle row matches 
000686,000017:    4577           04631                          TC       DISPALL                       	# Refresh DSKY	
000687,000018: 
000688,000019:    4600           14074                          TCF      MAINLOOP                      	#
000689,000020: 
000690,000021: 
000691,000022:    4601                        CANTSCROLL                                                 	#
000692,000023: 
000693,000024:    4601           14074                          TCF      MAINLOOP                      	#
000694,000025: 
000695,000026: 
000696,000027:    4602                        SCROLLDOWN                                                 	#
000697,000028: 
000698,000029:    4602           35230                          CA       DEC5                          	# Load 5 into A
000699,000030:    4603           54061                          TS       TEMPI                         	# Store in temp var
000700,000031: 
000701,000032:    4604           30156                          CA       HIS_IDX                       	# Load current start index
000702,000033:    4605           00006                          EXTEND                                 	#
000703,000034:    4606           14601                          BZF      CANTSCROLL                    	# If history index = 0, can't scroll
000704,000035: 
000705,000036:    4607           00006                          EXTEND                                 	#
000706,000037:    4610           60061                          SU       TEMPI                         	# Subtract 5 to move to prev row - can't use constant from fixed mem for SU
000707,000038:    4611           54156                          TS       HIS_IDX                       	# Store back in history index var
000708,000039: 
000709,000040:    4612           14575                          TCF      SCR_UPDT                      	# Update display with scrolled data
(End of include-file Scroll.agc, resuming Main.agc)
000710,000068: $ClearDigit.agc

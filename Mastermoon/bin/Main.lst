000153,000013:    4123           54103                          TS       END_ID                        	# Store to check against digit check index
000154,000014: 
000155,000015:    4124           30007                          CA       ZERO                          	# Load 0 into A
000156,000016:    4125           54074                          TS       CUR_ID                        	# Index to compare values
000157,000017:    4126           54122                          TS       RIGHT_TMP                     	# Number correct in right spot
000158,000018:    4127           54123                          TS       ALMOST_TMP                    	# Number correct in wrong spot
000159,000019: 
